{
  "name": "ikinamba",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev -w apps/server\" \"npm:dev -w apps/web\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "db:migrate": "npm run db:migrate -w apps/server",
    "db:seed": "npm run db:seed -w apps/server",
    "build": "npm run build -w apps/server && npm run build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
