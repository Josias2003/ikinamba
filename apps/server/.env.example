DATABASE_URL="mysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@localhost:3306/ikinamba"
JWT_SECRET="any-long-random-secret"
JWT_EXPIRES_IN="8h"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# SMTP (leave blank to auto-use an Ethereal test inbox in dev -- core login/booking
# still works without it, only emailed notifications/OTP won't actually deliver)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=""

# Ollama local AI (optional -- the chatbot widget needs this running; everything else
# in the system works without it)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="ikinamba-ai"

# MTN MoMo via the "Payments V1" product on developers.mtn.com (OAuth2 client-credentials
# auth -- Consumer Key/Secret from My Apps -> your app's expanded row). Optional -- leave
# blank to use the simulated MoMo provider instead of a real one. See
# docs/MOMO_SETUP_GUIDE.md. MOMO_BASE_URL and the exact endpoint paths are still being
# confirmed against the live API docs as of this writing -- do not assume these are final.
MOMO_BASE_URL="https://api.mtn.com/v1"
MOMO_CONSUMER_KEY=
MOMO_CONSUMER_SECRET=
MOMO_CURRENCY="RWF"
