DATABASE_URL="mysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@localhost:3306/ikinamba"
JWT_SECRET="any-long-random-secret"
JWT_EXPIRES_IN="8h"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# SMTP (leave blank to auto-use an Ethereal test inbox in dev -- core login/booking
# still works without it, only emailed notifications/OTP won't actually deliver)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=""

# Ollama local AI (optional -- the chatbot widget needs this running; everything else
# in the system works without it)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="ikinamba-ai"

# MTN MoMo (optional -- leave all four blank to use the simulated MoMo provider instead
# of a real one; see docs/MOMO_SETUP_GUIDE.md to get real sandbox values)
MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT="sandbox"
MOMO_CURRENCY="EUR"
