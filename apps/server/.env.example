DATABASE_URL="mysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@localhost:3306/ikinamba"
JWT_SECRET="any-long-random-secret"
JWT_EXPIRES_IN="8h"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# SMTP via Brevo (smtp-relay.brevo.com) -- free tier: 300 emails/day, works on Render.
# Setup: brevo.com → Sign up → SMTP & API → SMTP tab → Generate a new SMTP key.
# SMTP_USER = your Brevo account email address
# SMTP_PASS = the generated SMTP key (NOT your account password)
# Leave all blank to fall back to an Ethereal test inbox in dev.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="New Class Car Wash <no-reply@newclasscarwash.rw>"

# Ollama local AI (optional -- the chatbot widget needs this running; everything else
# in the system works without it)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="ikinamba-ai"

# MTN MoMo Collections sandbox -- see docs/MOMO_SETUP_GUIDE.md for the click-by-click
# setup on momodeveloper.mtn.com. Optional: leave all blank to use the simulated
# provider (payments still work in demo mode without real credentials).
MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENV="sandbox"
MOMO_CURRENCY="EUR"
