DATABASE_URL="mysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@localhost:3306/ikinamba"
JWT_SECRET="any-long-random-secret"
JWT_EXPIRES_IN="8h"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
# The single public-facing URL used in emails and QR codes (tracking links).
# Dev LAN: http://YOUR_WIFI_IP:5173  |  Production: https://your-app.onrender.com
APP_URL="http://localhost:5173"

# Brevo transactional email -- free tier: 300 emails/day, works on Render.
# Setup: brevo.com → SMTP & API → API Keys → Create a new API key.
# BREVO_FROM must be a verified sender in your Brevo account (Settings → Senders & IP).
# Leave BREVO_API_KEY blank to skip email sending in dev (app still works fine).
BREVO_API_KEY=
BREVO_FROM=
BREVO_SENDER_NAME="New Class Car Wash"

# Ollama local AI (optional -- the chatbot widget needs this running; everything else
# in the system works without it)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="ikinamba-ai"

# MTN MoMo Collections sandbox -- see docs/MOMO_SETUP_GUIDE.md for the click-by-click
# setup on momodeveloper.mtn.com. Optional: leave all blank to use the simulated
# provider (payments still work in demo mode without real credentials).
MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENV="sandbox"
MOMO_CURRENCY="EUR"

# Groq Whisper STT -- much better at Kinyarwanda names than browser Web Speech API.
# Free tier: groq.com → sign up → API Keys → Create key.
# Leave blank to keep using the browser's built-in speech recognition instead.
GROQ_API_KEY=
